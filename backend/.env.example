# Copy this file to .env and adjust values for your environment.

# SQLAlchemy database URL. Default stores the SQLite file under backend/data/.
DATABASE_URL=sqlite:///./data/gym.db

# Used to sign JWT access tokens. Generate a real secret for production, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# JWT algorithm and access token lifetime.
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Seed admin account created automatically on first startup if no admin exists.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@gymtrack.com
ADMIN_PASSWORD=change-me-admin-password

# Logging level for the application logger (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO
